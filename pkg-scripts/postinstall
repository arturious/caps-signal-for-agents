#!/bin/bash
set -euo pipefail

# postinstall runs as root, so $HOME here would be /var/root — agent-signal needs
# to write to the actual logged-in user's ~/.claude/settings.json instead.
CONSOLE_USER=$(stat -f%Su /dev/console)

if [ -z "$CONSOLE_USER" ] || [ "$CONSOLE_USER" = "root" ]; then
    echo "agent-signal: could not determine the logged-in user; skipping hook install."
    echo "agent-signal: run '/usr/local/bin/agent-signal install-hooks' manually."
    exit 0
fi

sudo -u "$CONSOLE_USER" /usr/local/bin/agent-signal install-hooks

exit 0
